{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",

        "lib": [
            "ES2022"
        ],

        "types": [
            "node",
            "vscode"
        ],

        "strict": true,

        "rootDir": "src",
        "outDir": "out",

        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },

    "include": [
        "src"
    ]
}